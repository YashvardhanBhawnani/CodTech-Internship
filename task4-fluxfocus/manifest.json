{
  "manifest_version": 3,
  "name": "FluxFocus",
  "description": "FluxFocus - Track smarter. Focus better.",
  "version": "1.0",
  "permissions": ["storage", "tabs", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "dist/index.html"
  }
}
